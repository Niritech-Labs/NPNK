%Make Backend
$cmake -S backend -B backend/build-o-critical
$cmake --build backend/build-o-critical

%Make Nuklear
$cmake -S libnuklear -B libnuklear/build-o-critical
$cmake --build libnuklear/build-o-critical

%Make Nuklear Bingings
$sh tools/preprocess.sh-o-critical
$python3 tools/generator.py-o-critical
$cmake -S npcore_nuklear -B npcore_nuklear/build-o-critical
$cmake --build npcore_nuklear/build-o-critical

%Install Nuklear
$sudo cmake --install libnuklear/build-o-critical
TRG:/usr/lib64-o-libnuklear/build/libnuklear.so-o-install-o-755


%Install on project
DIR:build-o-remove-o-755
DIR:build-o-install-o-755


TRG:build-o-libnuklear/build/libnuklear.so-o-install-o-755

$sh tools/install.sh-o-critical



%Clean Backend
DIR:backend/build-o-remove-o-755

%Clean Nuklear
DIR:libnuklear/build-o-remove-o-755

%Clean Nuklear Bingings
DIR:npcore_nuklear/build-o-remove-o-755

%Clean All
DIR:backend/build-o-remove-o-755
DIR:npcore_nuklear/build-o-remove-o-755
DIR:libnuklear/build-o-remove-o-755
DIR:build-o-remove-o-755