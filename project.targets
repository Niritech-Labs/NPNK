####################################################
%Make Backend WL
$cmake -S backend -B backend/build-o-critical
TRG:backend/build-o-libnuklear/build/libnuklear.so-o-install-o-755
$cmake --build backend/build -j-o-critical

%Make Nuklear WL
$cmake -S libnuklear -B libnuklear/build-o-critical
$cmake --build libnuklear/build-o-critical

%Make Nuklear Bingings WL
$sh tools/preprocess.sh-o-critical
$python3 tools/generator.py-o-critical
$cmake -S npcore_nuklear -B npcore_nuklear/build-o-critical
$cmake --build npcore_nuklear/build -j-o-critical
######################################################
%Make Backend WN
$cmake -S backend -B backend/build -DCMAKE_TOOLCHAIN_FILE=../tools/WIN32TC.cmake-o-critical
$cmake --build backend/build -j-o-critical


%Make Nuklear WN
$cmake -S libnuklear -B libnuklear/build -DCMAKE_TOOLCHAIN_FILE=../tools/WIN32TC.cmake-o-critical
$cmake --build libnuklear/build-o-critical


%Make Nuklear Bingings WN
$sh tools/preprocess.sh-o-critical
$python3 tools/generator.py-o-critical
$cmake -S npcore_nuklear -B npcore_nuklear/build -DCMAKE_TOOLCHAIN_FILE=../tools/WIN32TC.cmake-o-critical
$cmake --build npcore_nuklear/build -j-o-critical

######################################################################
%Install WL
DIR:src-o-install-o-755
DIR:src/NPNK-o-install-o-755
TRG:src/NPNK-o-libnuklear/build/libnuklear.so-o-install-o-755
$sh tools/install.sh-o-critical

%Install WN
TRG:src/NPNK-o-libnuklear/build/libnuklear.dll-o-install-o-755
$sh tools/install.sh-o-critical

###########################################################################
%Clean Subs
DIR:backend/build-o-remove-o-755
DIR:npcore_nuklear/build-o-remove-o-755
DIR:libnuklear/build-o-remove-o-755

%Сlean Final
DIR:src/NPNK-o-remove-o-755
DIR:src-o-remove-o-755


